# Copy this file to ".env" and edit values as needed.
# (Photo Wall server uses these values to write to Supabase from the local
# Node process. Do not put service_role keys into browser-facing files.)

# HTTP port. Defaults to 3100 to avoid clashing with the Typewriter
# subproject, which uses 3000.
# PORT=3100

# Supabase project URL.
# SUPABASE_URL=https://uhcgprnorihyvhrkxmpm.supabase.co

# Browser-safe publishable key.
# SUPABASE_ANON_KEY=sb_publishable_...

# Server-only secret key for local photo uploads and vote updates.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
